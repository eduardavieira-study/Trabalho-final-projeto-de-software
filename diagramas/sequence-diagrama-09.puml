@startuml UC09_RealizarAgendamento
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #555555
skinparam SequenceLifeLineBorderColor #333333

actor "Cliente" as Cliente
participant "Sistema" as Sistema
database "Banco de Dados" as BD

Cliente -> Sistema : consultarHorariosDisponiveis(servico, profissional, data)
Sistema -> BD : buscarHorarios(servico, profissional, data)
BD --> Sistema : listaDeHorarios
Sistema --> Cliente : exibirHorariosDisponiveis(listaDeHorarios)

Cliente -> Sistema : realizarAgendamento(clienteId, servicoId, profissionalId, horario)
Sistema -> BD : verificarDisponibilidade(profissionalId, horario)
BD --> Sistema : disponivel

alt horário disponível
  Sistema -> BD : salvarAgendamento(clienteId, servicoId, profissionalId, horario)
  BD --> Sistema : agendamentoConfirmado
  Sistema --> Cliente : exibirConfirmacao(agendamentoId, detalhes)
else horário indisponível
  Sistema --> Cliente : exibirErro("Horário não disponível. Escolha outro.")
end

@enduml