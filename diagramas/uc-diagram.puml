@startuml DudaSpa_CasosDeUso

left to right direction
skinparam packageStyle rectangle
skinparam backgroundColor #FAFAFA
skinparam ArrowColor #555555
skinparam ActorBorderColor #333333

actor "Usuário" as Usuario
actor "Cliente" as Cliente
actor "Funcionário" as Funcionario
actor "Recepcionista" as Recepcionista
actor "Gerente" as Gerente

Usuario <|-- Cliente
Usuario <|-- Funcionario
Usuario <|-- Recepcionista
Usuario <|-- Gerente

rectangle "Sistema Duda Spa" {

  package "Conta e Acesso" {

    usecase "UC-01\nCriar Conta" as UC01
    usecase "UC-02\nEditar Conta" as UC02
    usecase "UC-03\nExcluir Conta" as UC03
    usecase "UC-04\nFazer Login" as UC04
    usecase "UC-05\nRecuperar Senha" as UC05

  }

  package "Área do Cliente" {

    usecase "UC-06\nVisualizar Serviços e Promoções" as UC06
    usecase "UC-07\nVisualizar Profissionais" as UC07
    usecase "UC-08\nConsultar Horários Disponíveis" as UC08
    usecase "UC-09\nRealizar Agendamento" as UC09
    usecase "UC-10\nCancelar Agendamento" as UC10
    usecase "UC-11\nConsultar Histórico de Atendimentos" as UC11

  }

  package "Área do Funcionário" {

    usecase "UC-12\nConsultar Agenda de Atendimentos" as UC12
    usecase "UC-13\nRegistrar Evolução do Cliente" as UC13
    usecase "UC-14\nVisualizar Dados do Cliente" as UC14
    usecase "UC-15\nLançar Comissões" as UC15

  }

  package "Área da Recepcionista" {

    usecase "UC-16\nCadastrar Cliente" as UC16
    usecase "UC-17\nGerenciar Agendamentos da Equipe" as UC17
    usecase "UC-18\nLocalizar Agendamento do Cliente" as UC18
    usecase "UC-19\nRealizar Check-in" as UC19
    usecase "UC-20\nRegistrar Pagamento" as UC20

  }

  package "Área do Gerente" {

    usecase "UC-21\nAcompanhar Relatórios Financeiros" as UC21
    usecase "UC-22\nControlar Estoque de Produtos" as UC22
    usecase "UC-23\nGerenciar Serviços" as UC23
    usecase "UC-24\nGerenciar Promoções" as UC24

  }

}

Usuario --> UC01
Usuario --> UC02
Usuario --> UC03
Usuario --> UC04
Usuario --> UC05

Cliente --> UC06
Cliente --> UC07
Cliente --> UC08
Cliente --> UC09
Cliente --> UC10
Cliente --> UC11

Funcionario --> UC12
Funcionario --> UC13
Funcionario --> UC14
Funcionario --> UC15

Recepcionista --> UC16
Recepcionista --> UC17
Recepcionista --> UC18
Recepcionista --> UC19
Recepcionista --> UC20

Gerente --> UC21
Gerente --> UC22
Gerente --> UC23
Gerente --> UC24


UC09 ..> UC08 : <<include>>
UC19 ..> UC18 : <<include>>
UC20 ..> UC18 : <<include>>

UC05 ..> UC04 : <<extend>>
UC10 ..> UC09 : <<extend>>

@enduml